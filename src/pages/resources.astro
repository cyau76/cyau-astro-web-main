---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const resourceLinks = [
	{
		title: 'Advance by Blake Boyd',
		description: 'Patch sheet, stage plot, and run-of-show app copied into this codebase.',
		href: '/resources/advance-by-blake-boyd',
		cta: 'Open Advance App',
	},
	{
		title: 'Songs',
		description: 'Audio resources with streaming links and downloadable MP3 files.',
		href: '/resources/songs',
		cta: 'Open Songs Page',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Resources" description="Helpful links and audio resources" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Resources</h1>
			<section style="display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); margin-top: 1rem;">
				{resourceLinks.map((item) => (
					<article style="border: 1px solid #d0d7de; border-radius: 12px; padding: 1rem; background: #f8fafc; box-shadow: 0 3px 10px rgba(0,0,0,0.06);">
						<h2 style="margin-top: 0;">{item.title}</h2>
						<p>{item.description}</p>
						<p>
							<a href={item.href} style="display: inline-block; background: #2563eb; color: #fff; text-decoration: none; padding: 0.55rem 0.85rem; border-radius: 8px; font-weight: 600;">
								{item.cta}
							</a>
						</p>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
