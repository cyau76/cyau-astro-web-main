---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const resourceLinks = [
	{
		title: 'Advance by Blake Boyd',
		description: 'Patch sheet, stage plot, and run-of-show app copied into this codebase.',
		href: '/resources/advance-by-blake-boyd',
		cta: 'Open Advance App',
	},
	{
		title: 'Songs',
		description: 'Audio resources with streaming links and downloadable MP3 files.',
		href: '/resources/songs',
		cta: 'Open Songs Page',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Resources" description="Helpful links and audio resources" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Resources</h1>
			<section class="resource-grid">
				{resourceLinks.map((item) => (
					<article class="resource-card">
						<h2>{item.title}</h2>
						<p>{item.description}</p>
						<p>
							<a href={item.href} class="resource-cta">
								{item.cta}
							</a>
						</p>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.resource-grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		margin-top: 1rem;
	}

	.resource-card {
		border: 1px solid var(--border-color);
		border-radius: 0.75rem;
		padding: 1rem;
		background: var(--surface-color);
		box-shadow: 0 3px 10px rgba(var(--black), 0.08);
	}

	.resource-card h2 {
		margin-top: 0;
	}

	.resource-cta {
		display: inline-block;
		background: var(--accent);
		color: var(--accent-contrast);
		text-decoration: none;
		padding: 0.55rem 0.85rem;
		border-radius: 0.5rem;
		font-weight: 600;
	}

	.resource-cta:hover {
		background: var(--accent-dark);
	}
</style>
