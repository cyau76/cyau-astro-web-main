---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_TITLE } from '../../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`26 winter diffusions input list-Q&A | ${SITE_TITLE}`}
			description="Embedded document for 26 Winter Diffusions input list Q&A."
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>26 winter diffusions input list-Q&amp;A</h1>
			<p>Review the embedded document below. If it does not load, use the direct link.</p>
			<p>
				<a
					href="https://docs.google.com/document/d/1Mrdm7ieY2UVhaehldoK6SxQ_AcQqFD48zfSjE3X0rLs"
					target="_blank"
					rel="noopener noreferrer"
				>
					Open document in a new tab
				</a>
			</p>
			<div class="doc-wrap">
				<iframe
					src="https://docs.google.com/document/d/1Mrdm7ieY2UVhaehldoK6SxQ_AcQqFD48zfSjE3X0rLs/preview"
					title="26 winter diffusions input list-Q&A"
					loading="lazy"
				></iframe>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.doc-wrap {
		width: 100%;
		min-height: 1200px;
		border: 1px solid var(--border-color);
		border-radius: 0.75rem;
		overflow: hidden;
		background: var(--surface-color);
	}

	iframe {
		display: block;
		width: 100%;
		height: 1200px;
		border: 0;
	}
</style>
