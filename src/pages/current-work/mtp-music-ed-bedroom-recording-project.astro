---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const mixedFilePath = '/audio/bedroom-rec-proj-cyau.mp3';
const cloudLink = 'https://oregonstateuniversity-my.sharepoint.com/:f:/g/personal/auc_oregonstate_edu/IgDaUtxZ2wTqR5ze2rpcSrr4ATHtn7Fm_Lxt8LSK6g750pc?e=3ZCzzi';
const hasMixedFile = mixedFilePath.endsWith('.mp3');
const hasCloudLink = cloudLink.startsWith('http');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`MTP & Music Ed Bedroom Recording Project | ${SITE_TITLE}`}
			description="The following is a playable mp3 file and a link to onedrive"
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>MTP &amp; Music Ed Bedroom Recording Project</h1>
			<p>
				The following is a playable mp3 file and a link to onedrive (you must use OSU email)
			</p>

			<section>
				<h2>Mixed File (MP3)</h2>
				
				{hasMixedFile && (
					<audio controls preload="none" src={mixedFilePath}>
						Your browser does not support the audio element.
					</audio>
				)}
			</section>

			<section>
				<h2>Cloud Link</h2>
				
				{hasCloudLink && <p><a href={cloudLink}>Open cloud link</a></p>}
				
			</section>
		</main>
		<Footer />
	</body>
</html>
