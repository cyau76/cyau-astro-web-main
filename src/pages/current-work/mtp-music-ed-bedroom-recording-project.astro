---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const mixedFilePath = '[Add mixed mp3 path in repo, e.g. /audio/mtp-bedroom-project-mix-v1.mp3]';
const cloudLink = '[Add cloud link, e.g. https://drive.google.com/... ]';
const hasMixedFile = mixedFilePath.endsWith('.mp3');
const hasCloudLink = cloudLink.startsWith('http');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`MTP & Music Ed Bedroom Recording Project | ${SITE_TITLE}`}
			description="Project placeholders for mixed mp3 file and cloud link, editable via GitHub."
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>MTP &amp; Music Ed Bedroom Recording Project</h1>
			<p>
				This page uses editable placeholders so you can update project links directly in GitHub.
			</p>

			<section>
				<h2>Mixed File (MP3 in repo)</h2>
				<p>
					Current placeholder:
					<code>{mixedFilePath}</code>
				</p>
				<p>
					After you upload an MP3 file into <code>public/audio/</code>, replace the placeholder above
					with its public path.
				</p>
				{hasMixedFile && (
					<audio controls preload="none" src={mixedFilePath}>
						Your browser does not support the audio element.
					</audio>
				)}
			</section>

			<section>
				<h2>Cloud Link</h2>
				<p>Current placeholder: <code>{cloudLink}</code></p>
				{hasCloudLink && <p><a href={cloudLink}>Open cloud link</a></p>}
				<p>Replace the placeholder with your Google Drive, Dropbox, or other cloud URL.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
